AddType application/x-font-ttf .ttf
ErrorDocument 404 /

RewriteEngine On

# Исключить ВСЕ файлы внутри pwa/ и cache/
RewriteCond %{REQUEST_URI} ^/(pwa|cache)/ [NC]
RewriteRule ^ - [L]

RewriteBase /

RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d


#RewriteRule ^get_file/([0-9]+)/?$ /files/download.php?id=$1 [L,QSA,NC]
RewriteRule ^(.*)$ index.php?url=$1 [L,QSA]
#RewriteRule ^([0-9a-zA-Z/_-]+)$ index.php?url=$1 [QSA]
RewriteRule (.*)\/([^/]+)\.html$ $1/?path=$2 [QSA]
RewriteRule ([^/]+)\.site$ /site/?id=$1 [QSA]
RewriteRule ^([0-9a-zA-Z/_-]+)/page([0-9]+)/ $1?pn=$2&%{QUERY_STRING} [QSA]

php_flag display_startup_errors on
php_flag display_errors on
php_flag html_errors on
php_flag log_errors on
php_value error_log /var/www/html/logs/PHP_errors.log