# Запрещаем прямой доступ к файлам
Order Deny,Allow
Deny from all

RewriteEngine On
# Правило для преобразования /get_file/123 в /download.php?id=123
RewriteRule ^get_file/([0-9]+)/?$ /files/download.php?id=$1 [L,QSA,NC]

# Запрещаем прямой доступ к папке с файлами
RewriteRule ^files/ - [F,L]

# Разрешаем доступ только через PHP скрипты
<FilesMatch "\.(php)$">
    Allow from all
</FilesMatch>

#<Files *.php>
#    Deny from all
#</Files>

# Запрещаем листинг директорий
Options -Indexes

# Включаем отслеживание симлинков (для безопасности)
Options +FollowSymLinks -SymLinksIfOwnerMatch

<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/jpg "access plus 1 month"
    ExpiresByType image/jpeg "access plus 1 month"
    ExpiresByType image/gif "access plus 1 month"
    ExpiresByType image/png "access plus 1 month"
    ExpiresByType text/css "access plus 1 month"
    ExpiresByType application/pdf "access plus 1 month"
</IfModule>